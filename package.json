{
  "name": "medieval-road-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:e2e": "tsc && vite build",
    "preview": "vite preview",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173",
    "test:rust": "cargo test --manifest-path server/logic/Cargo.toml",
    "test:e2e": "playwright test",
    "smoketest": "playwright test e2e/smoke.spec.ts",
    "generate:world-bootstrap": "node --experimental-strip-types scripts/generateWorldBootstrap.mts",
    "generate:game-balance": "node --experimental-strip-types scripts/generateGameBalance.mts",
    "generate:hydrology-grid": "node --experimental-strip-types scripts/generateHydrologyGrid.mts",
    "test:lodge-logistics": "npx tsx scripts/testLodgeLogistics.mts",
    "test:village-economy": "npx tsx scripts/testVillageEconomy.mts",
    "test:chapel-community": "npx tsx scripts/testChapelCommunity.mts",
    "test:household-economy": "npx tsx scripts/testHouseholdEconomy.mts",
    "test:landmark-access": "npx tsx scripts/testLandmarkAccessParity.mts",
    "test:economy-parity": "npx tsx scripts/testEconomyParity.mts",
    "test:chapel-parish": "npx tsx scripts/testChapelParish.mts",
    "test:marketplace-gating": "npx tsx scripts/testMarketplaceGating.mts",
    "test:marketplace-trade": "npx tsx scripts/testMarketplaceTrade.mts",
    "test:settlement-schedule": "npx tsx scripts/testSettlementSchedule.mts",
    "test:seasons": "node --experimental-strip-types scripts/testSeasonSimulation.mts",
    "test:weather-visuals": "node --experimental-strip-types scripts/testPrecipitationVisuals.mts",
    "test:fires": "node --experimental-strip-types scripts/testFireSystem.mts",
    "test:world-config": "npx tsx scripts/testWorldConfigAuthority.mts",
    "test:connection-recovery": "npx tsx scripts/testConnectionRecoveryHints.mts",
    "test:building-processor-status": "npx tsx scripts/testBuildingProcessorStatus.mts",
    "test:chapel-bell-schedule": "npx tsx scripts/testChapelBellSchedule.mts",
    "test:expanded-settlement": "npx tsx scripts/testExpandedSettlement.mts",
    "test:farming": "npx tsx scripts/testFarming.mts",
    "test:monastery-polish": "npx tsx scripts/testMonasteryPolish.mts",
    "test:backyard-gardens": "npx tsx scripts/testBackyardGardenVisuals.mts",
    "test:residence-terrain": "node --experimental-strip-types scripts/testResidenceTerrainAdaptation.mts",
    "test:building-art": "npx tsx scripts/testBuildingArtDirection.mts",
    "test:camera-controller": "npx tsx scripts/testCameraController.mts",
    "test:first-person-collision": "node --experimental-strip-types scripts/testFirstPersonCollision.mts",
    "test:client-sync": "npx tsx scripts/testClientSyncScheduling.mts",
    "test:placement-regressions": "node --experimental-strip-types scripts/testPlacementRegressions.mts",
    "test:deer-wildlife": "npx tsx scripts/testDeerWildlife.mts",
    "test:livestock": "npx tsx scripts/testLivestock.mts",
    "test:agent-visuals": "node --experimental-strip-types scripts/testAgentVisualAssets.mts",
    "test:worker-agents": "node --experimental-strip-types scripts/testWorkerAgents.mts",
    "test:household-routines": "node --experimental-strip-types scripts/testHouseholdRoutines.mts",
    "test:civic-logistics": "npx tsx scripts/testCivicLogistics.mts",
    "test:construction-logistics": "node --experimental-strip-types scripts/testConstructionLogistics.mts",
    "test:quarry-balance": "node --experimental-strip-types scripts/testQuarryBalance.mts",
    "test:rich-stone": "node --experimental-strip-types scripts/testRichStoneSystem.mts",
    "test:fishing": "node --experimental-strip-types scripts/testFishingSystem.mts",
    "test:foraging-ecology": "node --experimental-strip-types scripts/testForagingEcology.mts",
    "test": "npm run test:ci",
    "test:ci": "npx tsx scripts/run-all-tests.mts",
    "deploy:local": "powershell -ExecutionPolicy Bypass -File ./server/deploy-local.ps1",
    "deploy:local-clean": "powershell -ExecutionPolicy Bypass -File ./server/deploy-local-clean.ps1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/three": "^0.185.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "spacetimedb": "2.0.1",
    "three": "^0.185.1"
  }
}
